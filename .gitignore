# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-results/
/playwright-report/

# next.js
/.next/
/out/

# generated announcement meta (built by prebuild scripts)
/public/announcements/index.generated.json

# generated SEO artifacts (built by prebuild scripts)
/public/og/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.claude
.history
.ace-tool/
.opencode
sync-game-data.config.json

# generated build artifacts (prebuild scripts)
/public/version.json
/public/changelog.json
/src/generated/version-data.ts
.codebuddy/
.workbuddy/
docs/superpowers/
artifacts
