  "suitEffects": [
    {
      "id": "passive_equipsuit_burst_01",
      "name": {
        "zh-CN": "潮涌",
        "en": "Tide Surge",
        "ja": "満潮",
        "zh-TW": "潮湧"
      },
      "description": {
        "zh-CN": "3件套组效果：装备者所有技能伤害<@ba.vup>+20%</>。\n装备者使敌人达到<@ba.key>2</>层及以上<#ba.spellinflict>法术附着</>后，造成的<@ba.key>法术伤害</><@ba.vup>+35%</>，持续15秒，该效果无法叠加。",
        "en": "3-piece set effect: Wearer's Skill DMG Dealt <@ba.vup>+20%</>.\nAfter the wearer applies <@ba.key>2</> or more stacks of <#ba.spellinflict>Arts Infliction</> on the enemy, the wearer gains <@ba.key>Arts DMG Dealt</> <@ba.vup>+35%</> for 15s. This effect cannot stack.",
        "ja": "3点セット効果：装備中、すべてのスキルダメージ<@ba.vup>+20%</>\n自身が敵の<#ba.spellinflict>アーツ付着</>段階を<@ba.key>2</>以上にすると、15秒間与える<@ba.key>アーツダメージ</><@ba.vup>+35%</>\nこの効果は重ね掛け不可",
        "zh-TW": "3件套裝效果：裝備者所有技能傷害<@ba.vup>+20%</>。\n裝備者使敵人達到<@ba.key>2</>層及以上<#ba.spellinflict>法術附著</>後，造成的<@ba.key>法術傷害</><@ba.vup>+35%</>，持續15秒，該效果無法疊加。"
      },
      "requiredPieces": 3
    }
  ],
