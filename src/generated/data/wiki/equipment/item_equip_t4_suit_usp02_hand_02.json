  "suitEffects": [
    {
      "id": "passive_equipsuit_usp_02",
      "name": {
        "zh-CN": "长息",
        "en": "Eternal Xiranite",
        "ja": "流転",
        "zh-TW": "長息"
      },
      "description": {
        "zh-CN": "3件套组效果：装备者生命值<@ba.vup>+1000</>。\n装备者施加<#ba.enhance>增幅</>、<#ba.guard>庇护</>、<#ba.vulnerable>脆弱</>、<#ba.weak>虚弱</>后，使其他队友造成的伤害<@ba.vup>+16%</>，持续15秒。该效果无法叠加。",
        "en": "3-piece set effect: Wearer's HP <@ba.vup>+1000</>.\nAfter the wearer applies <#ba.enhance>Amp</>, <#ba.guard>Protected</>, <#ba.vulnerable>Susceptibility</>, or <#ba.weak>Weakened</>, other teammates gain DMG Dealt <@ba.vup>+16%</> for 15s. This effect cannot stack.",
        "ja": "3点セット効果：装備中、HP<@ba.vup>+1000</>\n自身が<#ba.enhance>増幅</>、<#ba.guard>加護</>、<#ba.vulnerable>脆弱</>、<#ba.weak>弱体化</>を付与すると、15秒間編成中の他の味方の与えるダメージ<@ba.vup>+16%</>\nこの効果は重ね掛け不可",
        "zh-TW": "3件套裝效果：裝備者生命值<@ba.vup>+1000</>。\n裝備者施加<#ba.enhance>增幅</>、<#ba.guard>庇護</>、<#ba.vulnerable>脆弱</>、<#ba.weak>虛弱</>後，使其他隊友造成的傷害<@ba.vup>+16%</>，持續15秒。該效果無法疊加。"
      },
      "requiredPieces": 3
    }
  ],
