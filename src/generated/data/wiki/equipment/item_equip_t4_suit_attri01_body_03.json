  "suitEffects": [
    {
      "id": "passive_equipsuit_attrisuit_01",
      "name": {
        "zh-CN": "碾骨",
        "en": "Bonekrusha",
        "ja": "骨砕",
        "zh-TW": "碾骨"
      },
      "description": {
        "zh-CN": "3件套组效果：装备者攻击力<@ba.vup>+15%</>。\n当装备者施放连携技时，获得一层<@ba.key>碾骨重压</>，下一次的战技伤害<@ba.vup>+30%</>，<@ba.key>碾骨重压</>最多可叠加2层。",
        "en": "3-piece set effect: Wearer's ATK <@ba.vup>+15%</>. \nWhen the wearer casts a combo skill, the wearer gains 1 stack of <@ba.key>Bonekrushing Smash</> that grants the wearer's next battle skill DMG Dealt <@ba.vup>+30%</>. <@ba.key>Bonekrushing Smash</> can stack 2 time(s).",
        "ja": "3点セット効果：装備中、攻撃力<@ba.vup>+15%</>\n自身が連携技を発動するとき、<@ba.key>骨砕の重圧</>を1段階獲得し、次の戦技ダメージ<@ba.vup>+30%</>\n<@ba.key>骨砕の重圧</>は最大2段階まで重ね掛け可能",
        "zh-TW": "3件套裝效果：裝備者攻擊力<@ba.vup>+15%</>。\n當裝備者施放連攜技時，獲得一層<@ba.key>碾骨重壓</>，下一次的戰技傷害<@ba.vup>+30%</>，<@ba.key>碾骨重壓</>最多可疊加2層。"
      },
      "requiredPieces": 3,
      "values": {
        "atk_up": 0.15,
        "dmg_up": 0.3,
        "max_stack": 2
      }
    }
  ],
